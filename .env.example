# LLM API (at least one required)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# LLM model selection (optional, default deepseek-v4-pro via Dify plugin)
LLM_MODEL=deepseek-v4-pro

# Serper API (Google real-time search, for sentiment branch)
SERPER_API_KEY=your_serper_api_key

# Tushare Pro (financial data, for quant branch)
TUSHARE_TOKEN=your_tushare_token

# PDF preprocessing paths
RAW_PDF_DIR=./raw_pdfs
OUTPUT_DIR=./processed

# Vector database
CHROMA_PERSIST_DIR=./chroma_db

# Log level
LOG_LEVEL=INFO

# Service configuration
HOST=0.0.0.0
PORT=8000
MAX_WORKERS=4
